<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="multisafepay_redirect_token" resource="default" engine="innodb" comment="MultiSafepay Redirect Token">
        <column xsi:type="int" name="token_id" unsigned="true" nullable="false" identity="true" comment="Token ID" />
        <column xsi:type="varchar" name="order_increment_id" length="255" nullable="false" comment="Order Increment ID" />
        <column xsi:type="varchar" name="token" length="32" nullable="false" comment="Token" />
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At" />
        <column xsi:type="boolean" name="expired" nullable="false" default="0" comment="Expired" />

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="token_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="MULTISAFEPAY_REDIRECT_TOKEN_TOKEN_UNQ">
            <column name="token"/>
        </constraint>

        <index referenceId="MULTISAFEPAY_REDIRECT_TOKEN_ORDER_INCREMENT_ID" indexType="btree">
            <column name="order_increment_id"/>
        </index>
    </table>
</schema>
